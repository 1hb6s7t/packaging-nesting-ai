{
  "schema_version": 1,
  "description": "Offline webhook notification channel audit pack for operational go-live evidence.",
  "templates": [
    {
      "name": "Task Failure High Generic Webhook",
      "event_type": "work_task.failure_high",
      "channel": "webhook",
      "title_template": "Task queue failure threshold {job_id}",
      "message_template": "Failed tasks: {metrics.failed}; active tasks: {metrics.active}",
      "target_type": "work_task_metrics",
      "target_id": "work-task-failure-high",
      "context": {
        "job_id": "OPS-TASK-001",
        "metrics": {
          "failed": 12,
          "active": 42
        }
      },
      "payload": {
        "dedupe_key": "work-task-failure-high"
      },
      "metadata": {
        "webhook_provider": "generic",
        "webhook_url": "https://alerts.example.test/generic",
        "signature_secret": "audit-webhook-secret",
        "signature_header": "X-Audit-Signature",
        "signature_timestamp_header": "X-Audit-Timestamp",
        "dedupe_minutes": 30,
        "retry_count": 1
      },
      "audit_response_sequence": [503, 202],
      "expected_provider": "generic",
      "expect_signature": true,
      "expect_dedupe": true,
      "expected_attempt_count": 2
    },
    {
      "name": "Task Stale Running Feishu Webhook",
      "event_type": "work_task.stale_running",
      "channel": "webhook",
      "title_template": "PACKAGING-AI Stale task alert {job_id}",
      "message_template": "Stale running tasks: {metrics.stale_running}",
      "target_type": "work_task_metrics",
      "target_id": "work-task-stale-running",
      "context": {
        "job_id": "OPS-TASK-STALE",
        "metrics": {
          "stale_running": 3
        }
      },
      "payload": {
        "dedupe_key": "work-task-stale-running"
      },
      "metadata": {
        "webhook_provider": "feishu",
        "webhook_url": "https://open.feishu.cn/open-apis/bot/v2/hook/audit",
        "platform_keyword": "PACKAGING-AI",
        "dedupe_minutes": 30,
        "retry_count": 1
      },
      "audit_response_sequence": [200],
      "expected_provider": "feishu",
      "expect_dedupe": true,
      "expected_attempt_count": 1
    },
    {
      "name": "Procurement Shortage WeCom Webhook",
      "event_type": "procurement.material_shortage",
      "channel": "webhook",
      "title_template": "Procurement shortage {material.code}",
      "message_template": "Shortage {material.shortage} for job {job_id}",
      "target_type": "nesting_job",
      "target_id": "procurement-shortage",
      "context": {
        "job_id": "JOB-PROC-001",
        "material": {
          "code": "WHITE-350",
          "shortage": 320
        }
      },
      "payload": {
        "dedupe_key": "procurement-shortage"
      },
      "metadata": {
        "webhook_provider": "wecom",
        "webhook_message_type": "markdown",
        "webhook_url": "https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=audit",
        "dedupe_minutes": 30,
        "retry_count": 1
      },
      "audit_response_sequence": [200],
      "expected_provider": "wecom",
      "expect_dedupe": true,
      "expected_attempt_count": 1
    },
    {
      "name": "Production Schedule Blocked Generic Webhook",
      "event_type": "production.schedule_blocked",
      "channel": "webhook",
      "title_template": "Schedule blocked {job_id}",
      "message_template": "Schedule status {schedule.status}; blocked orders {schedule.blocked_count}",
      "target_type": "nesting_job",
      "target_id": "schedule-blocked",
      "context": {
        "job_id": "JOB-SCHED-001",
        "schedule": {
          "status": "blocked",
          "blocked_count": 2
        }
      },
      "payload": {
        "dedupe_key": "production-schedule-blocked"
      },
      "metadata": {
        "webhook_provider": "generic",
        "webhook_url": "https://alerts.example.test/schedule",
        "signature_secret": "audit-schedule-secret",
        "signature_header": "X-Audit-Schedule-Signature",
        "signature_timestamp_header": "X-Audit-Schedule-Timestamp",
        "dedupe_minutes": 30,
        "retry_count": 1
      },
      "audit_response_sequence": [204],
      "expected_provider": "generic",
      "expected_attempt_count": 1,
      "expect_signature": true,
      "expect_dedupe": true
    },
    {
      "name": "Production Delivery Incomplete WeCom Text",
      "event_type": "production.delivery_incomplete",
      "channel": "webhook",
      "title_template": "Delivery incomplete {job_id}",
      "message_template": "Delivered {delivery.delivered}; expected {delivery.expected}",
      "target_type": "nesting_job",
      "target_id": "delivery-incomplete",
      "context": {
        "job_id": "JOB-DELIVERY-001",
        "delivery": {
          "delivered": 800,
          "expected": 1200
        }
      },
      "payload": {
        "dedupe_key": "production-delivery-incomplete"
      },
      "metadata": {
        "webhook_provider": "wecom",
        "webhook_message_type": "text",
        "webhook_url": "https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=audit-delivery",
        "dedupe_minutes": 30,
        "retry_count": 1
      },
      "audit_response_sequence": [200],
      "expected_provider": "wecom",
      "expect_dedupe": true,
      "expected_attempt_count": 1
    },
    {
      "name": "Task Failure High Email",
      "event_type": "work_task.failure_high",
      "channel": "email",
      "title_template": "Email task failure threshold {job_id}",
      "message_template": "Failed tasks: {metrics.failed}; active tasks: {metrics.active}",
      "recipient_permission_code": "audit:read",
      "target_type": "work_task_metrics",
      "target_id": "work-task-failure-high-email",
      "context": {
        "job_id": "OPS-TASK-EMAIL",
        "metrics": {
          "failed": 12,
          "active": 42
        }
      },
      "payload": {
        "dedupe_key": "work-task-failure-high-email"
      },
      "metadata": {
        "email_subject_prefix": "[OPS] ",
        "dedupe_minutes": 30
      },
      "expected_recipient_email": "admin@example.com",
      "expected_subject": "[OPS] Email task failure threshold OPS-TASK-EMAIL",
      "expect_dedupe": true
    }
  ]
}
